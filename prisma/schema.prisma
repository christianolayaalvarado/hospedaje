generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId

  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?

  password       String?

  role           Role      @default(USER)

  bookings       Booking[]

  accounts       Account[]
  sessions       Session[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId

  userId             String  @db.ObjectId

  type               String
  provider           String
  providerAccountId  String

  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  sessionToken  String   @unique

  userId        String   @db.ObjectId
  expires       DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  identifier  String

  token       String   @unique
  expires     DateTime

  @@unique([identifier, token])
}

model Property {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId

  title        String
  slug         String    @unique

  description  String

  basePrice    Float
  cleaningFee  Float     @default(50)
  serviceFee   Float     @default(30)

  bookings     Booking[]
  seasons      SeasonalPrice[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  propertyId    String   @db.ObjectId
  property      Property @relation(fields: [propertyId], references: [id])

  userId        String   @db.ObjectId
  user          User @relation(fields: [userId], references: [id])

  startDate     DateTime
  endDate       DateTime

  totalPrice    Float
  subtotalPrice Float?
  discountValue Float?

  discountCodeId String? @db.ObjectId
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])

  paymentProof  String?
  paymentProofUploadedAt DateTime?

  expiresAt     DateTime?

  approvedAt    DateTime?

  cancelledAt   DateTime?

  status        BookingStatus @default(PENDING_PAYMENT)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SeasonalPrice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  propertyId  String   @db.ObjectId
  property    Property @relation(fields: [propertyId], references: [id])

  title       String

  startDate   DateTime
  endDate     DateTime

  price       Float

  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscountCode {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  code            String   @unique
  description     String?

  type            DiscountType

  value           Float

  maxUses         Int?
  usedCount       Int      @default(0)

  expiresAt       DateTime?

  active          Boolean  @default(true)

  bookings        Booking[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING_PAYMENT
  PAYMENT_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}
